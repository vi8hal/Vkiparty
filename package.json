    "framer-motion": "^11.0.8",
    "ioredis": "^5.10.1",
    "iron-session": "^8.0.1",
    "jose": "^5.2.3",
    "lucide-react": "^0.344.0",
    "next": "14.1.3",
    "nodemailer": "^6.9.11",
    "react": "^18",
    "react-dom": "^18",
    "react-hot-toast": "^2.4.1",
    "react-intersection-observer": "^9.8.1",
