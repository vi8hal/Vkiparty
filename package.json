{
  "name": "manki-party-grassroots-connect",
  "version": "1.0.0",
  "description": "Manki Party — Digital Grassroots Political Network for India",
  "private": true,
  "scripts": {
    "dev": "concurrently \"next dev\" \"node src/server/socket.js\"",
    "build": "next build",
    "start": "next start",
    "socket": "node src/server/socket.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "DATABASE_URL=$DATABASE_URL_MIGRATE prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:push": "DATABASE_URL=$DATABASE_URL_MIGRATE prisma db push",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
